# ── Gemini API ──
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Server ──
PORT=3000
NODE_ENV=development

# ── AMD vLLM (for hackathon deployment on MI300X) ──
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=meta-llama/Llama-3.1-70B-Instruct
# VLLM_VISION_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct
# LLM_PROVIDER=vllm
LLM_PROVIDER=gemini
